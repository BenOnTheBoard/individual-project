{
  "compileOnSave": false,
  "compilerOptions": {
    "paths": {
      "*": ["./*"]
    },
    "esModuleInterop": true,
    "outDir": "./dist/out-tsc",
    "sourceMap": true,
    "declaration": false,
    "experimentalDecorators": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "importHelpers": true,
    "rootDir": "./",
    "target": "es2015",
    "types": ["node"],
    "strict": false,
    "noUnusedLocals": true
  },
  "exclude": ["./cypress.config.ts"],
  "angularCompilerOptions": {
    "strictTemplates": true,
    "strictInjectionParameters": true
  }
}
